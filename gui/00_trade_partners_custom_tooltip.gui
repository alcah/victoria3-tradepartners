@tooltip_max_width = 550 #copied from tooltip.gui

@tooltip_fixed_width = 500 #for 2 column layouts etc, since max_width is quite wide
@tooltip_fixed_column_width = 245 #tooltip_fixed_width/2 - 10/2
@tooltip_fixed_column_width_minus_40 = 205
@tooltip_fixed_column_width_minus_16 = 229

types TooltipTypes {

type RegularTooltip_MarketWorldMarketImportPartners = RegularTooltip {
		blockoverride "tooltip_content_after" {
			flowcontainer = {
				direction = vertical
				margin_top = 10

				custom_tooltip_textbox = {
					text = "TRADE_PARTNERS_IMPORTED_GOODS_TITLE"
				}

				# in scope here: 
				# Scope.GetMarket -> Other market
				# Market -> Player's market
				flowcontainer = {
					datamodel = "[Scope.GetMarket.GetExports]"
					margin_top = 5
					wrap_count = 4

					item = {
						flowcontainer = {
							visible = "[GreaterThanOrEqualTo_CFixedPoint(Scope.GetMarket.GetExportedAmountToMarket(Market.Self, Goods.Self), '(CFixedPoint)1')]"

							background = {
								using = entry_bg_simple
							}
							margin = { 8 6 }
							spacing = 7

							icon = {
								size = { 23 23 }
								texture = "[Goods.GetTexture]"
								parentanchor = vcenter
							}

							custom_tooltip_textbox = {
								text = "[Scope.GetMarket.GetExportedAmountToMarket(Market.Self, Goods.Self)|v0]"
								autoresize = yes
								align = nobaseline
								parentanchor = vcenter
								minimumsize = { 50 -1 }
								maximumsize = { 50 -1 }
								using = elide_fontsize_min
								multiline = no
			}

							tooltipwidget = {
								FancyTooltip_Goods = {}
							}
						}
					}
				}
			}
		}
}
type RegularTooltip_MarketWorldMarketExportPartners = RegularTooltip {
		blockoverride "tooltip_content_after" {
			flowcontainer = {
				direction = vertical
				margin_top = 10

				custom_tooltip_textbox = {
					text = "TRADE_PARTNERS_EXPORTED_GOODS_TITLE"
				}

				# in scope here: 
				# Scope.GetMarket -> Other market
				# Market -> Player's market
				flowcontainer = {
					datamodel = "[Scope.GetMarket.GetImports]"
					margin_top = 5
					wrap_count = 4

					item = {
						flowcontainer = {
							visible = "[GreaterThanOrEqualTo_CFixedPoint(Scope.GetMarket.GetImportedAmountFromMarket(Market.Self, Goods.Self), '(CFixedPoint)1')]"

							background = {
								using = entry_bg_simple
							}
							margin = { 8 6 }
							spacing = 7

							icon = {
								size = { 23 23 }
								texture = "[Goods.GetTexture]"
								parentanchor = vcenter
							}

							custom_tooltip_textbox = {
								text = "[Scope.GetMarket.GetImportedAmountFromMarket(Market.Self, Goods.Self)|v0]"
								autoresize = yes
								align = nobaseline
								parentanchor = vcenter
								minimumsize = { 50 -1 }
								maximumsize = { 50 -1 }
								using = elide_fontsize_min
								multiline = no
			}

							tooltipwidget = {
								FancyTooltip_Goods = {}
							}
						}
					}
				}
			}
		}
}

# Called from the tooltip for another country's market 
# Market = other country's market
type RegularTooltip_MarketOtherMarketImportExport = RegularTooltip {
		blockoverride "tooltip_content_after" {
			flowcontainer = {
				direction = vertical

				custom_tooltip_textbox = {
					text = "TRADE_PARTNERS_OTHER_MARKET_IMPORTS_TOOLTIP"
				}
				datacontext = "[Market]"
				flowcontainer = {
					datamodel = "[Market.GetImports]"
					margin_top = 5
					wrap_count = 4

					item = {
						flowcontainer = {
							visible = "[GreaterThanOrEqualTo_CFixedPoint(Market.GetImportedAmountFromMarket(GetPlayer.GetMarket.Self, Goods.Self), '(CFixedPoint)1')]"

							background = {
								using = entry_bg_simple
							}
							margin = { 8 6 }
							spacing = 7

							icon = {
								size = { 23 23 }
								texture = "[Goods.GetTexture]"
								parentanchor = vcenter
							}

							custom_tooltip_textbox = {
								text = "[Market.GetImportedAmountFromMarket(GetPlayer.GetMarket.Self, Goods.Self)|v0]"
								autoresize = yes
								align = nobaseline
								parentanchor = vcenter
								minimumsize = { 50 -1 }
								maximumsize = { 50 -1 }
								using = elide_fontsize_min
								multiline = no
							}

							tooltipwidget = {
								FancyTooltip_Goods = {}
							}
						}
					}
				}
			}			
			flowcontainer = {
				direction = vertical
				margin_top = 10
				custom_tooltip_textbox = {
					text = "TRADE_PARTNERS_OTHER_MARKET_EXPORTS_TOOLTIP"
				}
				datacontext = "[Market]"
				flowcontainer = {
					datamodel = "[Market.GetExports]"
					margin_top = 5
					wrap_count = 4

					item = {
						flowcontainer = {
							visible = "[GreaterThanOrEqualTo_CFixedPoint(Market.GetExportedAmountToMarket(GetPlayer.GetMarket.Self, Goods.Self), '(CFixedPoint)1')]"

							background = {
								using = entry_bg_simple
							}
							margin = { 8 6 }
							spacing = 7

							icon = {
								size = { 23 23 }
								texture = "[Goods.GetTexture]"
								parentanchor = vcenter
							}

							custom_tooltip_textbox = {
								text = "[Market.GetExportedAmountToMarket(GetPlayer.GetMarket.Self, Goods.Self)|v0]"
								autoresize = yes
								align = nobaseline
								parentanchor = vcenter
								minimumsize = { 50 -1 }
								maximumsize = { 50 -1 }
								using = elide_fontsize_min
								multiline = no
							}

							tooltipwidget = {
								FancyTooltip_Goods = {}
							}
						}
					}
				}
			}
		}
}

type FancyTooltip_Market = FancyTooltipWidgetType {
		blockoverride "tooltip_content_before_before" {
			flowcontainer = {
				direction = vertical
				custom_tooltip_textbox = {
					datacontext = "[Market]"
					text = "TRADE_PARTNERS_MARKET_TOOLTIP_VALUES"
				}
				tooltipwidget = {
					RegularTooltip_MarketOtherMarketImportExport = {}
				}	
			}
		}

		blockoverride "text" {
			text = "DATA_MARKET_NAME_TOOLTIP"
		}

		blockoverride "name" {
			text = "[Market.GetNameNoFormatting]"
		}

		blockoverride "type" {
			text = "TOOLTIP_TYPE_MARKET"
		}

		blockoverride "color" {
			color = "[Market.GetOwner.GetMapColor]"
		}

		blockoverride "replace_icon" {
			small_flag = {
				parentanchor = center
				datacontext = "[Market.GetOwner]"
			}
		}

		blockoverride "icon_background_texture" {}

		blockoverride "icon_frame" {}

		### Changed position due to using a flag
		blockoverride "tooltip_icon_position"{
			position = { 11 3 }
		}

		### Changed margin due to changing the position of the flag
		blockoverride "header_text_margin_left" {
			margin_left = 72
		}

		blockoverride "go_to_button_visibility" {
			visible = yes
		}

		blockoverride "go_to_button_properties" {
			onclick = "[InformationPanelBar.OpenMarketPanel(Market.Self)]"
		}

		blockoverride "tooltip_content_after"
		{
			datacontext = "[Market.GetFoodSecurity]"

			custom_tooltip_newline = {}

			custom_tooltip_textbox = {
				text = "DATA_MARKET_STARVATION_HEADER"
			}

			flowcontainer = {
				direction = vertical
				datamodel = "[GetStarvationTypes]"

				item = {
					flowcontainer = {
						spacing = 5
						margin_left = 10

						icon = {
							parentanchor = vcenter
							size = { 25 25 }
							texture = "[StarvationType.GetIcon]"
						}

						custom_tooltip_textbox = {
							parentanchor = vcenter
							text = "DATA_MARKET_STARVATION_ENTRY"
						}
					}
				}
			}

			custom_tooltip_newline = {
				visible = "[FoodSecurity.HasFamine]"
			}

			custom_tooltip_textbox = {
				visible = "[FoodSecurity.HasFamine]"
				text = "HAS_ONGOING_FAMINES"
			}

			widget = {
				size = { 15 15 }
			}

			flowcontainer = {
				using = tooltip_segment_background
				direction = vertical
				margin_top = 15
				margin_bottom = 10

				custom_tooltip_textbox = {
					text = "WORLD_MARKET_TRADE"
					autoresize = yes
					align = right|nobaseline
					parentanchor = hcenter
					margin_bottom = 10
				}

				flowcontainer = {
					spacing = 20


					flowcontainer = {
						direction = vertical
						margin_left = 4

						flowcontainer = {
							spacing = 1

							icon = {
								texture = "gfx/interface/icons/trade_icons/imports.dds"
								size = { 23 23 }
							}

							custom_tooltip_textbox = {
								text = "MARKET_IMPORTS"
								margin_bottom = 5
								margin_left = 5
								autoresize = yes
								align = right|nobaseline
							}
						}

						flowcontainer = {
							datamodel = "[DataModelFirst(Market.GetImports, '(int32)10')]"
							parentanchor = right
							direction = vertical

							item = {
								flowcontainer = {
									spacing = 5
									parentanchor = right

									minimumsize = { 200 -1 }
									margin = { 3 3 }

									tooltipwidget = {
										FancyTooltip_Goods = {}
									}

									background = {
										visible = "[IsEven_int32(PdxGuiWidget.GetIndexInDataModel)]"
										using = dark_area
									}

									icon = {
										size = { 23 23 }
										texture = "[Goods.GetTexture]"
										parentanchor = vcenter
									}

									custom_tooltip_textbox = {
										text = "[Goods.GetMarketImports|vD]"
										autoresize = yes
										align = nobaseline
										parentanchor = vcenter
										minimumsize = { 40 -1 }
										maximumsize = { 40 -1 }
										fontsize_min = 12
									}

									overlappingitembox = {
										datamodel = "[Goods.GetExportersToMarket]"
										size = { 115 18 }
										spacing = 5
										righttoleft = yes
										parentanchor = vcenter

										item = {
											small_market_flag = {
												parentanchor = vcenter
											}
										}
									}
								}
							}
						}
					}

					flowcontainer = {
						direction = vertical
						margin_left = 4

						flowcontainer = {
							spacing = 1

							icon = {
								texture = "gfx/interface/icons/trade_icons/exports.dds"
								size = { 23 23 }
							}

							custom_tooltip_textbox = {
								text = "MARKET_EXPORTS"
								margin_bottom = 5
								margin_left = 5
								autoresize = yes
								align = right|nobaseline
							}
						}

						flowcontainer = {
							datamodel = "[DataModelFirst(Market.GetExports, '(int32)10')]"
							parentanchor = right
							direction = vertical

							item = {
								flowcontainer = {
									spacing = 5
									parentanchor = right

									minimumsize = { 200 -1 }
									margin = { 3 3 }

									tooltipwidget = {
										FancyTooltip_Goods = {}
									}

									background = {
										visible = "[IsEven_int32(PdxGuiWidget.GetIndexInDataModel)]"
										using = dark_area
									}

									icon = {
										size = { 23 23 }
										texture = "[Goods.GetTexture]"
									}

									custom_tooltip_textbox = {
										text = "[Goods.GetMarketExports|vD]"
										autoresize = yes
										align = nobaseline
										parentanchor = vcenter
										minimumsize = { 40 -1 }
										maximumsize = { 40 -1 }
										fontsize_min = 12
									}

									overlappingitembox = {
										datamodel = "[Goods.GetImportersFromMarket]"
										size = { 115 18 }
										spacing = 5
										righttoleft = yes
										parentanchor = vcenter

										item = {
											small_market_flag = {
												parentanchor = vcenter
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}
