types market_panel {
    type trade_partners_charts = flowcontainer {
        spacing = 10        
        # Check both since it's possbible to have just one side
       visible = "[Or(GreaterThan_int32(GetDataModelSize(Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_export')), '(int32)0'),GreaterThan_int32(GetDataModelSize(Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_import')), '(int32)0'))]"
        compact_chart = {
            blockoverride "datamodel" {
                datamodel = "[Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_export')]"
            }

            blockoverride "show_more_button_visibility" {
                visible = "[GreaterThan_int32(GetDataModelSize(Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_export')), '(int32)3')]"
            }

            blockoverride "heading" {
                text = "TRADE_PARTNERS_EXPORT_PARTNERS_GRAPH_TITLE"
            }

            blockoverride "tooltip" {
                tooltip = "TRADE_PARTNERS_EXPORT_PARTNERS_TITLE"
                tooltipwidget = {
                    RegularTooltip_MarketWorldMarketExportPartners = {}
                }
            }

            blockoverride "pieslice" {
                value = "[GuiScope.SetRoot( Scope.GetMarket.MakeScope ).AddScope('base_market', Market.MakeScope).ScriptValue('trade_partners_total_imports_from_target')]"
            }

            blockoverride "color" {
                color = "[Scope.GetMarket.GetOwner.GetMapColor]"
            }
            
            blockoverride "pie_item_goto_button" {
                button = {
                    using = clean_button
                    size = { 100% 100% }
                    onclick = "[InformationPanelBar.OpenMarketPanel(Scope.GetMarket.Self)]"    
                }
            }

            blockoverride "leftside_info" {
                visible = no
            }

            blockoverride "rightside1_info" {
                raw_text = " [Scope.GetMarket.GetOwner.GetFlagTextIcon] [GuiScope.SetRoot( Scope.GetMarket.MakeScope ).AddScope('base_market', Market.MakeScope).ScriptValue('trade_partners_total_imports_from_target')|vD]"
            }

            blockoverride "rightside2_info" {
                visible = no
            }
        }

        compact_chart = {
            blockoverride "datamodel" {
                datamodel = "[Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_import')]"
            }

            blockoverride "show_more_button_visibility" {
                visible = "[GreaterThan_int32(GetDataModelSize(Market.GetOwner.MakeScope.GetList('trade_partners_all_markets_import')), '(int32)3')]"
            }

            blockoverride "heading" {
                text = "TRADE_PARTNERS_IMPORT_PARTNERS_GRAPH_TITLE"
            }

            blockoverride "tooltip" {
                tooltip = "TRADE_PARTNERS_IMPORT_PARTNERS_TITLE"
                tooltipwidget = {
                    RegularTooltip_MarketWorldMarketImportPartners = {}
                }
            }

            blockoverride "pieslice" {
                value = "[GuiScope.SetRoot( Scope.GetMarket.MakeScope ).AddScope('base_market', Market.MakeScope).ScriptValue('trade_partners_total_exports_to_target')]"
            }

            blockoverride "color" {
                color = "[Scope.GetMarket.GetOwner.GetMapColor]"
            }
            
            blockoverride "pie_item_goto_button" {
                button = {
                    using = clean_button
                    size = { 100% 100% }
                    onclick = "[InformationPanelBar.OpenMarketPanel(Scope.GetMarket.Self)]"    
                }
            }

            blockoverride "leftside_info" {
                visible = no
            }

            blockoverride "rightside1_info" {
                raw_text = " [Scope.GetMarket.GetOwner.GetFlagTextIcon] [GuiScope.SetRoot( Scope.GetMarket.MakeScope ).AddScope('base_market', Market.MakeScope).ScriptValue('trade_partners_total_exports_to_target')|vD]"
            }

            blockoverride "rightside2_info" {
                visible = no
            }
        }
    }
}
